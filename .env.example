# PostgreSQL (required for Netlify — free DB: https://neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Your live site URL (Netlify example below)
APP_URL="https://your-site.netlify.app"
NEXT_PUBLIC_APP_URL="https://your-site.netlify.app"

# Auth — generate: openssl rand -hex 32
JWT_SECRET="your-long-random-jwt-secret-at-least-32-chars"
ADMIN_JWT_SECRET=""

# Admin (for db:seed / db:setup-safe)
ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="use-a-strong-password-here"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Checkout wallet numbers
NEXT_PUBLIC_BKASH_NUMBER="01XXXXXXXXX"
NEXT_PUBLIC_NAGAD_NUMBER="01XXXXXXXXX"
