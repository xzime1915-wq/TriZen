# ─── Local SQLite (default for now) ───
DATABASE_URL="file:./dev.db"

# ─── PostgreSQL (later — Supabase) ───
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?sslmode=require"

# Production (HTTPS): https://trizenstore.com.bd
# Local dev: http://localhost:3000
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

JWT_SECRET="your-long-random-jwt-secret-at-least-32-chars"

ADMIN_EMAIL="admin@yourdomain.com"
ADMIN_PASSWORD="use-a-strong-password-here"

# Google Cloud Console → OAuth client (Web application)
# Redirect URI: {APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Checkout OTP — Bahari business email (support@trizenstore.com.bd)
SMTP_HOST="mail.datacorelink.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="support@trizenstore.com.bd"
SMTP_PASS=""
EMAIL_FROM="TRIZEN STORE <support@trizenstore.com.bd>"
EMAIL_REPLY_TO="support@trizenstore.com.bd"

# bKash Tokenized Checkout (merchant account)
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
# Sandbox: https://tokenized.sandbox.bka.sh/v1.2.0-beta
# Live:    https://tokenized.pay.bka.sh/v1.2.0-beta
BKASH_BASE_URL="https://tokenized.pay.bka.sh/v1.2.0-beta"
# Optional — defaults to {APP_URL}/api/payments/bkash/callback
# BKASH_CALLBACK_URL="https://trizenstore.com.bd/api/payments/bkash/callback"

# Optional: Order + live chat alerts on your phone
#
# ── Recommended: Telegram (CallMeBot — no API key, bot usually replies) ──
# 1) Open https://t.me/CallMeBot_txtbot → send /start
# 2) Set your @username:
TELEGRAM_ADMIN_USER="@yourtelegramusername"
#
# ── WhatsApp: CallMeBot (bot often offline / no reply) ──
# 1) WhatsApp এ +34 644 76 66 43 কে contact এ যোগ করুন (নাম: CallMeBot)
#    পুরোনো +34 644 44 71 67 অফলাইন — অফিসিয়াল: callmebot.com
# 2) সেই নম্বরে মেসেজ: "I allow callmebot to send me messages"
# 3) উত্তরে apikey পাবেন → নিচে বসান
CALLMEBOT_PHONE="+8801XXXXXXXXX"
CALLMEBOT_APIKEY=""
#
# ── Option B: Meta WhatsApp Cloud API (business) ──
# developers.facebook.com → WhatsApp → API Setup
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_ADMIN_PHONE="8801XXXXXXXXX"
